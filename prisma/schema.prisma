generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
 
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  age      Int?
}

model Food {
  id       Int     @id @default(autoincrement())
  name String
  price String
  category FoodCategory @relation(fields: [foodCategoyId], references: [id] )
 foodCategoyId Int

 createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt
 }

 model FoodCategory {
 id       Int     @id @default(autoincrement())
  name String
  foods Food[]

  createdAt DateTime @default(now())
 updatedAt DateTime @updatedAt 
 }